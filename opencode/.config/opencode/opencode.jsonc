{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/gpt-4.1",
    "plugin": [
        "opencode-wakatime", // Tracks coding activity and sends metrics to WakaTime
        "@mohak34/opencode-notifier@latest",
        "@franlol/opencode-md-table-formatter@0.0.3"
    ],
    "provider": {
        "github-copilot": {
            "models": {
                "gpt-4.1": {
                    "name": "GPT-4.1"
                },
                "gpt-4o": {
                    "name": "GPT-4o"
                },
                "gpt-4o-mini": {
                    "name": "GPT-4o mini"
                }
            }
        }
    }
}